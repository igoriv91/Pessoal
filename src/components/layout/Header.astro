---
const navLinks = [
  { label: 'Sobre', href: '#sobre' },
  { label: 'Stack', href: '#stack' },
  { label: 'Projetos', href: '#projetos' },
  { label: 'Contato', href: '#contato' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-slate-950/80 backdrop-blur-md border-b border-slate-800">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="#" class="text-slate-100 font-semibold text-lg tracking-tight hover:text-indigo-400 transition-colors">
      Igor Vitor
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="text-slate-400 hover:text-slate-100 text-sm font-medium transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      aria-label="Abrir menu"
      aria-expanded="false"
      class="md:hidden flex flex-col gap-1.5 p-2 rounded text-slate-400 hover:text-slate-100"
    >
      <span class="block w-5 h-0.5 bg-current transition-all duration-300" id="bar1"></span>
      <span class="block w-5 h-0.5 bg-current transition-all duration-300" id="bar2"></span>
      <span class="block w-5 h-0.5 bg-current transition-all duration-300" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-slate-800 bg-slate-950"
  >
    <ul class="flex flex-col px-6 py-4 gap-4">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="mobile-nav-link block text-slate-300 hover:text-indigo-400 text-base font-medium transition-colors py-1"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;

  toggle.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');

    if (isOpen) {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      bar1.style.transform = '';
      bar2.style.opacity = '';
      bar3.style.transform = '';
    } else {
      menu.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      bar1.style.transform = 'translateY(8px) rotate(45deg)';
      bar2.style.opacity = '0';
      bar3.style.transform = 'translateY(-8px) rotate(-45deg)';
    }
  });

  // Fechar menu ao clicar em link
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      bar1.style.transform = '';
      bar2.style.opacity = '';
      bar3.style.transform = '';
    });
  });
</script>
