---
const sections = [
  { id: 'hero',     label: 'Início'   },
  { id: 'sobre',    label: 'Sobre'    },
  { id: 'stack',    label: 'Stack'    },
  { id: 'projetos', label: 'Projetos' },
  { id: 'contato',  label: 'Contato'  },
];
---

<nav class="side-nav" aria-label="Navegação por seção">
  <!-- Linha conectora (só desktop) -->
  <div class="side-nav__line" aria-hidden="true"></div>

  {sections.map(section => (
    <a
      href={`#${section.id}`}
      class="side-nav__item"
      data-section={section.id}
      aria-label={`Ir para ${section.label}`}
    >
      <span class="side-nav__dot" aria-hidden="true"></span>
      <span class="side-nav__label">{section.label}</span>
    </a>
  ))}
</nav>

<style>
  /* ─── BASE (mobile-first: barra horizontal na base) ─────────────────── */

  .side-nav {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;

    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.25rem;

    background: rgba(15, 23, 42, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(71, 85, 105, 0.4);
    border-radius: 9999px;
    padding: 0.5rem 1rem;
  }

  /* Linha: oculta no modo horizontal */
  .side-nav__line {
    display: none;
  }

  /* Item */
  .side-nav__item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    text-decoration: none;
    outline: none;
    border-radius: 9999px;
    transition: background 0.2s ease;
  }

  .side-nav__item:hover {
    background: rgba(99, 102, 241, 0.1);
  }

  /* Dot */
  .side-nav__dot {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background-color: #334155;
    border: 1.5px solid #475569;
    transition: all 0.25s ease;
    flex-shrink: 0;
  }

  .side-nav__item:hover .side-nav__dot {
    background-color: #818cf8;
    border-color: #818cf8;
    transform: scale(1.25);
  }

  .side-nav__item.is-active .side-nav__dot {
    width: 10px;
    height: 10px;
    background-color: #6366f1;
    border-color: #6366f1;
    box-shadow: 0 0 8px #6366f180;
  }

  /* Label: oculta no modo horizontal (mobile/tablet) */
  .side-nav__label {
    display: none;
  }

  /* ─── DESKTOP (≥ 1280px): lateral esquerda vertical ─────────────────── */

  @media (min-width: 768px) {
    .side-nav {
      /* Reset do modo horizontal */
      bottom: auto;
      left: 1.75rem;
      top: 0;
      transform: none;

      flex-direction: column;
      align-items: center;
      gap: 0;

      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border: none;
      border-radius: 0;
      padding: 0;

      /* Centralizar verticalmente */
      height: 100vh;
      justify-content: center;
      pointer-events: none;
    }

    /* Linha vertical */
    .side-nav__line {
      display: block;
      position: absolute;
      top: calc(50% - (5 * 2rem) / 2 + 12px);
      height: calc(5 * 2rem - 24px);
      left: 4px;
      width: 1px;
      background: linear-gradient(to bottom, transparent, #334155 20%, #334155 80%, transparent);
    }

    .side-nav__item {
      position: relative;
      z-index: 1;
      padding: 0.75rem 0;
      pointer-events: auto;
      background: transparent;
    }

    .side-nav__item:hover {
      background: transparent;
    }

    /* Label: visível ao hover/ativo no desktop */
    .side-nav__label {
      display: block;
      position: absolute;
      left: 1.25rem;
      white-space: nowrap;
      font-size: 0.75rem;
      font-weight: 500;
      color: #64748b;
      opacity: 0;
      transform: translateX(-4px);
      transition: opacity 0.2s ease, transform 0.2s ease, color 0.2s ease;
      pointer-events: none;
    }

    .side-nav__item:hover .side-nav__label,
    .side-nav__item:focus-visible .side-nav__label {
      opacity: 1;
      transform: translateX(0);
      color: #cbd5e1;
    }

    .side-nav__item.is-active .side-nav__label {
      opacity: 1;
      transform: translateX(0);
      color: #a5b4fc;
    }
  }
</style>

<script>
  const items = document.querySelectorAll<HTMLElement>('.side-nav__item');
  const sections = Array.from(
    document.querySelectorAll<HTMLElement>('section[id]')
  );

  function setActive(id: string) {
    items.forEach(item => {
      item.classList.toggle('is-active', item.dataset.section === id);
    });
  }

  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
        }
      });
    },
    { rootMargin: '-35% 0px -55% 0px', threshold: 0 }
  );

  sections.forEach(section => observer.observe(section));

  setActive('hero');

  items.forEach(item => {
    item.addEventListener('click', e => {
      e.preventDefault();
      const target = document.getElementById(item.dataset.section!);
      target?.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>
