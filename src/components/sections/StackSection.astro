---
import { Icon } from "astro-icon/components";
import { stack, extras, SKILL_LEVELS } from "../../data/stack";
---

<section id="stack" class="py-24 flex justify-center">
	<div class="md:ml-22 max-w-6xl px-6">
		<div class="mb-12">
			<p
				class="text-indigo-400 font-semibold text-sm uppercase tracking-widest mb-3"
			>
				Tecnologias
			</p>
			<h2 class="text-3xl md:text-4xl font-bold text-slate-100">
				Stack principal
			</h2>
		</div>

		<!-- Tech cards -->
		<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-10">
			{
				stack.map((tech) => (
					<div class="group bg-slate-800/60 border border-slate-700/50 hover:border-indigo-500/50 rounded-xl p-5 text-center transition-all duration-200 hover:bg-slate-800">
						<span
							class="w-8 h-8 mb-3 mx-auto block"
							style={`color: ${tech.iconColor}`}
							aria-hidden="true"
						>
							<Icon name={tech.icon} class="w-full h-full" />
						</span>
						<p class="text-slate-100 font-semibold text-sm mb-1">{tech.name}</p>
						<p class="text-slate-500 text-xs mb-3">{tech.category}</p>
						<p class="text-[10px] text-transparent group-hover:text-slate-400 transition-colors duration-200">
							{SKILL_LEVELS[tech.level]}
						</p>
						<div class="flex gap-1 mt-1">
							{Array.from({ length: 5 }, (_, i) => (
								<span
									class="flex-1 h-1 rounded-sm"
									style={
										i < tech.level
											? `background-color: ${tech.iconColor}`
											: undefined
									}
									class:list={[i >= tech.level && "bg-slate-700/60"]}
								/>
							))}
						</div>
					</div>
				))
			}
		</div>

		<!-- Extras -->
		<div>
			<p class="text-slate-500 text-sm mb-4 font-medium">Também trabalho com</p>
			<div class="flex flex-wrap gap-2">
				{
					extras.map((tag) => (
						<span class="bg-slate-800/60 border border-slate-700/40 text-slate-400 text-xs font-medium px-3 py-1.5 rounded-full">
							{tag}
						</span>
					))
				}
			</div>
		</div>
	</div>
</section>
