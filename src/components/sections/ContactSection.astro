---
const links = [
  {
    label: 'LinkedIn',
    description: 'Conecte-se comigo no LinkedIn',
    href: 'https://www.linkedin.com/in/igor-vitor-1141bb3b3/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>`,
  },
  {
    label: 'GitHub',
    description: 'Veja meus repositórios de estudo',
    href: 'https://github.com/igoriv91',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
  },
];
---

<section id="contato" class="py-24">
  <div class="max-w-6xl mx-auto px-6">

    <div class="max-w-2xl mx-auto text-center">
      <p class="text-indigo-400 font-semibold text-sm uppercase tracking-widest mb-3">Contato</p>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-100 mb-4">
        Vamos conversar?
      </h2>
      <p class="text-slate-400 leading-relaxed mb-10">
        Estou aberto a novos projetos, desafios e oportunidades. Entre em contato
        pelo LinkedIn — é o melhor canal para falar comigo.
      </p>

      <!-- Links -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
        {links.map(link => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-3 bg-slate-800/60 hover:bg-slate-800 border border-slate-700/50 hover:border-indigo-500/50 rounded-xl px-6 py-4 transition-all duration-200"
          >
            <span class="text-slate-400 group-hover:text-indigo-400 transition-colors" set:html={link.icon} />
            <div class="text-left">
              <p class="text-slate-100 font-semibold text-sm">{link.label}</p>
              <p class="text-slate-500 text-xs">{link.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>

  </div>
</section>

<!-- Footer -->
<footer class="border-t border-slate-800 py-8">
  <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-slate-500 text-sm">
      © {new Date().getFullYear()} Igor Vitor. Todos os direitos reservados.
    </p>
    <p class="text-slate-600 text-xs">
      Feito com <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-indigo-500 hover:text-indigo-400 transition-colors">Astro</a>
    </p>
  </div>
</footer>
