---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import profilePhoto from "../../assets/igor-vitor.png";
import { hero } from "../../data/hero";

const photoBg = "#090909";
---

<section
	id="hero"
	class="flex flex-col md:block relative min-h-screen overflow-hidden"
	style={`background-color: ${photoBg};`}
>
	<!-- ── TEXTO ──────────────────────────────────────────────────────────
       Mobile : flui no topo (order-1)
       Desktop: absolute, centralizado verticalmente à esquerda
  ─────────────────────────────────────────────────────────────────── -->
	<div
		class="relative z-10 px-6 pt-10 pb-6 md:absolute md:inset-0 md:flex md:items-center md:pt-0 md:pb-0 md:ml-22"
	>
		<div class="w-full md:w-[45%]">
			<h1
				class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-slate-100 leading-tight mb-5"
			>
				{hero.firstName}<br />
				<span class="text-indigo-400">{hero.lastName}</span>
			</h1>

			<p class="text-xl text-slate-300 font-medium mb-4">
				{hero.title}
			</p>

			<p class="text-slate-400 text-base leading-relaxed mb-10 max-w-sm">
				{hero.bio}
			</p>

			<div class="flex flex-wrap gap-4">
				{hero.links.map((link) => (
					<a
						href={link.href}
						target="_blank"
						rel="noopener noreferrer"
						class:list={[
							"inline-flex items-center gap-2 font-semibold px-6 py-3 rounded-lg transition-colors",
							link.variant === "primary"
								? "bg-indigo-600 hover:bg-indigo-500 text-white"
								: "border border-slate-600 hover:border-indigo-400 hover:text-indigo-400 text-slate-300",
						]}
					>
						<Icon name={link.icon} class="w-5 h-5" />
						{link.label}
					</a>
				))}
			</div>
		</div>
	</div>

	<!-- ── FOTO ───────────────────────────────────────────────────────────
       Mobile : flex-1 → ocupa a metade inferior restante da tela
       Desktop: absolute, metade direita, altura total
  ─────────────────────────────────────────────────────────────────── -->
	<div
		class="relative pointer-events-none select-none h-100
           md:absolute md:inset-y-0 md:right-0 md:w-[52%] md:flex-none md:min-h-0 md:h-full"
	>
		<Image
			src={profilePhoto}
			alt="Igor Vitor — Head of Development"
			width={900}
			height={1200}
			loading="eager"
			fetchpriority="high"
			class="w-full h-full object-cover object-top"
		/>

		<!-- Mobile: gradiente no topo da foto — funde com o fundo da seção -->
		<div
			class="md:hidden absolute inset-x-0 top-0 h-36"
			style={`background: linear-gradient(to bottom, ${photoBg}, transparent);`}
		>
		</div>

		<!-- Desktop: gradiente lateral esquerdo -->
		<div
			class="hidden md:block absolute inset-0"
			style={`background: linear-gradient(to right, ${photoBg} 0%, ${photoBg}cc 15%, ${photoBg}55 35%, transparent 65%);`}
		>
		</div>

		<!-- Ambos: gradiente inferior -->
		<div
			class="absolute inset-x-0 bottom-0 h-48"
			style={`background: linear-gradient(to top, ${photoBg}, transparent);`}
		>
		</div>
	</div>

	<!-- Scroll hint: só no desktop -->
	<a
		href="#sobre"
		class="hidden md:flex absolute bottom-10 left-1/2 -translate-x-1/2 flex-col items-center gap-2 text-slate-500 hover:text-indigo-400 transition-colors text-sm z-10"
		aria-label="Ir para seção Sobre"
	>
		<span>Saiba mais</span>
		<Icon name="ph:caret-down" class="w-5 h-5 animate-bounce" />
	</a>
</section>
