---
import { Image } from "astro:assets";
import profilePhoto from "../../assets/igor-vitor.png";

const photoBg = "#090909";
---

<section
	id="hero"
	class="flex flex-col md:block relative min-h-screen overflow-hidden"
	style={`background-color: ${photoBg};`}
>
	<!-- ── TEXTO ──────────────────────────────────────────────────────────
       Mobile : flui no topo (order-1)
       Desktop: absolute, centralizado verticalmente à esquerda
  ─────────────────────────────────────────────────────────────────── -->
	<div
		class="relative z-10 px-6 pt-10 pb-6 md:absolute md:inset-0 md:flex md:items-center md:pt-0 md:pb-0 md:ml-22"
	>
		<div class="w-full md:w-[45%]">
			<h1
				class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-slate-100 leading-tight mb-5"
			>
				Igor<br />
				<span class="text-indigo-400">Vitor</span>
			</h1>

			<p class="text-xl text-slate-300 font-medium mb-4">
				Head of Development & Full Stack Developer
			</p>

			<p class="text-slate-400 text-base leading-relaxed mb-10 max-w-sm">
				13 anos construindo produtos do zero e modernizando sistemas legados.
				Especialista em CRM, fidelização, apps mobile e integrações bancárias.
			</p>

			<div class="flex flex-wrap gap-4">
				<a
					href="https://www.linkedin.com/in/igor-vitor-1141bb3b3/"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="w-5 h-5"
						fill="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
						></path>
					</svg>
					LinkedIn
				</a>

				<a
					href="https://github.com/igoriv91"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 border border-slate-600 hover:border-indigo-400 hover:text-indigo-400 text-slate-300 font-semibold px-6 py-3 rounded-lg transition-colors"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="w-5 h-5"
						fill="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
						></path>
					</svg>
					GitHub
				</a>
			</div>
		</div>
	</div>

	<!-- ── FOTO ───────────────────────────────────────────────────────────
       Mobile : flex-1 → ocupa a metade inferior restante da tela
       Desktop: absolute, metade direita, altura total
  ─────────────────────────────────────────────────────────────────── -->
	<div
		class="relative pointer-events-none select-none h-100
           md:absolute md:inset-y-0 md:right-0 md:w-[52%] md:flex-none md:min-h-0 md:h-full"
	>
		<Image
			src={profilePhoto}
			alt="Igor Vitor — Head of Development"
			width={900}
			height={1200}
			loading="eager"
			fetchpriority="high"
			class="w-full h-full object-cover object-top"
		/>

		<!-- Mobile: gradiente no topo da foto — funde com o fundo da seção -->
		<div
			class="md:hidden absolute inset-x-0 top-0 h-36"
			style={`background: linear-gradient(to bottom, ${photoBg}, transparent);`}
		>
		</div>

		<!-- Desktop: gradiente lateral esquerdo -->
		<div
			class="hidden md:block absolute inset-0"
			style={`background: linear-gradient(to right, ${photoBg} 0%, ${photoBg}cc 15%, ${photoBg}55 35%, transparent 65%);`}
		>
		</div>

		<!-- Ambos: gradiente inferior -->
		<div
			class="absolute inset-x-0 bottom-0 h-48"
			style={`background: linear-gradient(to top, ${photoBg}, transparent);`}
		>
		</div>
	</div>

	<!-- Scroll hint: só no desktop -->
	<a
		href="#sobre"
		class="hidden md:flex absolute bottom-10 left-1/2 -translate-x-1/2 flex-col items-center gap-2 text-slate-500 hover:text-indigo-400 transition-colors text-sm z-10"
		aria-label="Ir para seção Sobre"
	>
		<span>Saiba mais</span>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			class="w-5 h-5 animate-bounce"
			fill="none"
			viewBox="0 0 24 24"
			stroke="currentColor"
		>
			<path
				stroke-linecap="round"
				stroke-linejoin="round"
				stroke-width="2"
				d="M19 9l-7 7-7-7"></path>
		</svg>
	</a>
</section>
